# ─── Variables de entorno de la aplicación ─────────────────────────────────────
#
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores según tu entorno.
#   3. NUNCA commitees el archivo .env al repositorio git.
#      El .gitignore ya lo excluye.
#
# En producción usa un gestor de secretos:
#   - AWS Secrets Manager
#   - HashiCorp Vault
#   - GitHub Actions Secrets
#   - Docker Secrets (Swarm mode)

# ─── Identidad ──────────────────────────────────────────────────────────────
APP_NAME=demo-api
APP_VERSION=1.0.0
ENVIRONMENT=development   # development | staging | production

# ─── Servidor ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR

# ─── Redis ───────────────────────────────────────────────────────────────────
# Local:       redis://localhost:6379
# Docker:      redis://redis:6379
# Con auth:    redis://:password@redis:6379
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=60

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
